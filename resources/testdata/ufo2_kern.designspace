<?xml version='1.0' encoding='UTF-8'?>
<!-- Minimal UFO2 font for testing @MMK_L_/@MMK_R_ kerning group upconversion -->
<designspace format="4.1">
  <axes>
    <axis tag="wght" name="Weight" minimum="400" maximum="400" default="400"/>
  </axes>
  <sources>
    <source filename="Ufo2Kern-Regular.ufo" name="Ufo2Kern Regular" familyname="Ufo2Kern" stylename="Regular">
      <lib copy="1"/>
      <groups copy="1"/>
      <features copy="1"/>
      <info copy="1"/>
      <location>
        <dimension name="Weight" xvalue="400"/>
      </location>
    </source>
  </sources>
</designspace>
