FILE@[0; 279)
  #@0 "# The spec says valueRecordDef is top-level only, but feaLib accepts"
  WS@68 "\n"
  #@69 "# them inside feature and lookup blocks, and real fonts use this"
  WS@133 "\n"
  #@134 "# (e.g. Google Sans Arabic)."
  WS@162 "\n"
    FeatureNode@[163; 213)
      FeatureKw@163 "feature"
      WS@170 " "
      Tag@171 "test"
      WS@175 " "
      {@176 "{"
      WS@177 "\n    "
        ValueRecordDefNode@[182; 205)
          ValueRecordDefKw@182 "valueRecordDef"
          WS@196 " "
            ValueRecordNode@[197; 200)
              NUM@197 "123"
          WS@200 " "
          ID@201 "foo"
          ;@204 ";"
      WS@205 "\n"
      }@206 "}"
      WS@207 " "
      Tag@208 "test"
      ;@212 ";"
  WS@213 "\n\n"
    LookupBlockNode@[215; 278)
      LookupKw@215 "lookup"
      WS@221 " "
      LABEL@222 "shmookup"
      WS@230 " "
      {@231 "{"
      WS@232 "\n    "
        ValueRecordDefNode@[237; 266)
          ValueRecordDefKw@237 "valueRecordDef"
          WS@251 " "
            ValueRecordNode@[252; 261)
              <@252 "<"
              NUM@253 "4"
              WS@254 " "
              NUM@255 "3"
              WS@256 " "
              NUM@257 "2"
              WS@258 " "
              NUM@259 "1"
              >@260 ">"
          WS@261 " "
          ID@262 "bar"
          ;@265 ";"
      WS@266 "\n"
      }@267 "}"
      WS@268 " "
      LABEL@269 "shmookup"
      ;@277 ";"
  WS@278 "\n"
